PORT=3001
# Public URL for listing image links (set to your EC2/domain in production)
API_BASE_URL=http://localhost:3001

# Optional override for the Expo web export directory
# FRONTEND_DIST=/path/to/moveinn/frontend/dist

# Local PostgreSQL (peer auth via unix socket)
PGHOST=/var/run/postgresql
PGDATABASE=rentrent

# Or use a full connection string (Docker / remote)
# DATABASE_URL=postgresql://rentrent:rentrent@localhost:5432/rentrent
